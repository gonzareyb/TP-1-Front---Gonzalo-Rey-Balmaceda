---
import Layout from '../layouts/Layout.astro';
import CardConsola from '../components/cardconsola.astro';

const consolas = [
  { nombre: "NES", anio: 1983, generacion: "3ra Gen", descripcion: "La consola que salvó la industria de los videojuegos. Hogar de Mario, Zelda y Metroid.", emoji: "🎮", ventas: "61.9 millones" },
  { nombre: "Game Boy", anio: 1989, generacion: "Portátil", descripcion: "La portátil más icónica de la historia. Tetris como juego incluido la convirtió en fenómeno.", emoji: "🟩", ventas: "118.7 millones" },
  { nombre: "Super Nintendo", anio: 1990, generacion: "4ta Gen", descripcion: "Gráficos Mode 7, sonido increíble y una biblioteca de juegos legendaria.", emoji: "🕹️", ventas: "49.1 millones" },
  { nombre: "Nintendo 64", anio: 1996, generacion: "5ta Gen", descripcion: "El salto a las 3D con Mario 64, Ocarina of Time y GoldenEye 007.", emoji: "⭐", ventas: "32.9 millones" },
  { nombre: "Game Boy Color", anio: 1998, generacion: "Portátil", descripcion: "La evolución de la Game Boy original con pantalla a color y nueva biblioteca.", emoji: "🌈", ventas: "118.7 millones" },
  { nombre: "GameCube", anio: 2001, generacion: "6ta Gen", descripcion: "El cubo morado de Nintendo con discos miniDVD y títulos únicos como Sunshine y Melee.", emoji: "🟪", ventas: "21.7 millones" },
  { nombre: "Game Boy Advance", anio: 2001, generacion: "Portátil", descripcion: "La portátil de 32 bits con una biblioteca enorme incluyendo ports de SNES.", emoji: "🎯", ventas: "81.5 millones" },
  { nombre: "Nintendo DS", anio: 2004, generacion: "Portátil", descripcion: "Doble pantalla, táctil y micrófono. Revolucionó la forma de jugar en portátiles.", emoji: "📱", ventas: "154.0 millones" },
  { nombre: "Wii", anio: 2006, generacion: "7ma Gen", descripcion: "Control por movimiento que abrió los juegos a un público completamente nuevo.", emoji: "📡", ventas: "101.6 millones" },
  { nombre: "Nintendo 3DS", anio: 2011, generacion: "Portátil", descripcion: "Pantalla 3D sin gafas, cámara y una biblioteca enorme incluyendo Pokemon y Zelda.", emoji: "🔵", ventas: "76.0 millones" },
  { nombre: "Wii U", anio: 2012, generacion: "8va Gen", descripcion: "GamePad táctil como segundo monitor. Subestimada pero con grandes exclusivos.", emoji: "📺", ventas: "13.6 millones" },
  { nombre: "Nintendo Switch", anio: 2017, generacion: "Híbrida", descripcion: "La consola híbrida más exitosa. Jugá en TV o en modo portátil con los mismos juegos.", emoji: "🔴", ventas: "146.0 millones" },
  { nombre: "Nintendo Switch Lite", anio: 2019, generacion: "Híbrida", descripcion: "Versión portátil de la Switch, más pequeña y económica, solo modo portátil.", emoji: "🟡", ventas: "22.8 millones" },
  { nombre: "Nintendo Switch OLED", anio: 2021, generacion: "Híbrida", descripcion: "Switch mejorada con pantalla OLED de 7 pulgadas y base con puerto LAN.", emoji: "⚪", ventas: "13.0 millones" },
];

const generaciones = ["Todas", ...new Set(consolas.map(c => c.generacion))];
---

<Layout title="Consolas Nintendo">
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-icon">🕹️</div>
      <h1 class="page-title">Consolas Nintendo</h1>
      <p class="page-subtitle">Desde la NES hasta la Switch — la historia del hardware que cambió los videojuegos</p>
    </div>
  </section>

  <section class="catalogo container">

    <!-- FILTROS -->
    <div class="filtros">
      <div class="filtro-grupo">
        <label class="filtro-label">🎮 Generación</label>
        <div class="filtro-btns" id="filtroGen">
          {generaciones.map(g => (
            <button class={`filtro-btn ${g === "Todas" ? "active" : ""}`} data-valor={g}>
              {g}
            </button>
          ))}
        </div>
      </div>

      <div class="filtro-grupo">
        <label class="filtro-label">🔍 Buscar</label>
        <input type="text" id="busqueda" class="filtro-input" placeholder="Nombre de la consola..." />
      </div>
    </div>

    <p class="resultado-count" id="contador">{consolas.length} consolas encontradas</p>

    <div class="grid-cards" id="gridConsolas">
      {consolas.map((consola, i) => (
        <div style={`animation-delay: ${i * 0.05}s`} data-generacion={consola.generacion} data-nombre={consola.nombre.toLowerCase()}>
          <CardConsola {...consola} />
        </div>
      ))}
    </div>

    <div class="empty-state" id="emptyState" style="display:none">
      <span>😢</span>
      <p>No se encontraron consolas con esos filtros.</p>
    </div>

  </section>
</Layout>

<style>
  .page-hero {
    background: radial-gradient(ellipse at center, rgba(10,122,191,0.15) 0%, transparent 70%), var(--bg);
    padding: 4rem 1.5rem 2rem;
    text-align: center;
  }

  .page-hero-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .page-subtitle {
    color: var(--text-muted);
    font-size: 1rem;
    margin-top: 0.5rem;
    max-width: 500px;
    margin-inline: auto;
    line-height: 1.6;
  }

  .catalogo {
    padding: 3rem 1.5rem 5rem;
  }

  .filtros {
    background: var(--card);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .filtro-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .filtro-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filtro-btn {
    background: var(--bg2);
    border: 2px solid transparent;
    border-radius: 8px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.35rem 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filtro-btn:hover {
    border-color: var(--accent3);
    color: var(--accent3);
  }

  .filtro-btn.active {
    background: var(--accent3);
    color: white;
    border-color: var(--accent3);
  }

  .filtro-input {
    width: 100%;
    max-width: 320px;
    background: var(--bg2);
    border: 2px solid transparent;
    border-radius: 8px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 0.5rem 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .filtro-input:focus { border-color: var(--accent3); }
  .filtro-input::placeholder { color: var(--text-muted); }

  .resultado-count {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    font-weight: 700;
  }

  .empty-state {
    text-align: center;
    padding: 4rem;
    color: var(--text-muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .empty-state span { font-size: 3rem; }

  @media (max-width: 600px) {
    .filtro-input { max-width: 100%; }
  }
</style>

<script>
  let genActiva = "Todas";
  let busquedaActiva = "";

  const grid = document.getElementById("gridConsolas");
  const items = grid?.querySelectorAll("[data-generacion]") ?? [];
  const contador = document.getElementById("contador");
  const emptyState = document.getElementById("emptyState");

  function filtrar() {
    let visibles = 0;

    items.forEach((item) => {
      const gen = item.getAttribute("data-generacion") ?? "";
      const nombre = item.getAttribute("data-nombre") ?? "";

      const matchGen = genActiva === "Todas" || gen === genActiva;
      const matchBusqueda = nombre.includes(busquedaActiva.toLowerCase());

      const visible = matchGen && matchBusqueda;
      (item as HTMLElement).style.display = visible ? "" : "none";
      if (visible) visibles++;
    });

    if (contador) contador.textContent = `${visibles} consola${visibles !== 1 ? "s" : ""} encontrada${visibles !== 1 ? "s" : ""}`;
    if (emptyState) emptyState.style.display = visibles === 0 ? "flex" : "none";
    if (grid) (grid as HTMLElement).style.display = visibles === 0 ? "none" : "grid";
  }

  document.getElementById("filtroGen")?.querySelectorAll(".filtro-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      document.getElementById("filtroGen")?.querySelectorAll(".filtro-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      genActiva = btn.getAttribute("data-valor") ?? "Todas";
      filtrar();
    });
  });

  document.getElementById("busqueda")?.addEventListener("input", (e) => {
    busquedaActiva = (e.target as HTMLInputElement).value;
    filtrar();
  });
</script>