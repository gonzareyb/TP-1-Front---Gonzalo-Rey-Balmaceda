---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
 
<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Nintendo World</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Nunito:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="navbar">
      <a href="/" class="navbar-logo">
        <span class="logo-icon">🍄</span>
        <span class="logo-text">Nintendo World</span>
      </a>
      <div class="navbar-links">
        <a href="/mario" class="nav-link">Mario</a>
        <a href="/consolas" class="nav-link">Consolas</a>
        <a href="/clima" class="nav-link">Clima</a>
      </div>
      <button class="dark-toggle" id="darkToggle" aria-label="Toggle dark mode">
        <span class="toggle-icon">🌙</span>
      </button>
    </nav>
 
    <main>
      <slot />
    </main>
 
    <footer class="footer">
      <p>Nintendo World · Hecho con <span style="color: var(--accent)">♥</span> y Astro</p>
    </footer>
  </body>
</html>
 
<style is:global>
  /* ===== VARIABLES ===== */
  :root {
    --bg: #0f0f1a;
    --bg2: #1a1a2e;
    --card: #16213e;
    --border: #e52521;
    --text: #f0f0f0;
    --text-muted: #a0a0b0;
    --accent: #e52521;
    --accent2: #fbd000;
    --accent3: #0a7abf;
    --radius: 12px;
    --font-pixel: "Press Start 2P", monospace;
    --font-body: "Nunito", sans-serif;
    --nav-height: 64px;
    --transition: 0.3s ease;
  }
 
  [data-theme="light"] {
    --bg: #f5f5f0;
    --bg2: #e8e8e0;
    --card: #ffffff;
    --text: #1a1a2e;
    --text-muted: #555566;
  }
 
  /* ===== RESET ===== */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
 
  html {
    scroll-behavior: smooth;
  }
 
  body {
    font-family: var(--font-body);
    background-color: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    transition: background-color var(--transition), color var(--transition);
  }
 
  main {
    flex: 1;
    padding-top: var(--nav-height);
  }
 
  a {
    text-decoration: none;
    color: inherit;
  }
 
  img {
    max-width: 100%;
    display: block;
  }
 
  /* ===== NAVBAR ===== */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--nav-height);
    background: var(--bg2);
    border-bottom: 3px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    z-index: 100;
    box-shadow: 0 4px 20px rgba(229, 37, 33, 0.2);
  }
 
  .navbar-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-pixel);
    font-size: 0.65rem;
    color: var(--accent2);
    letter-spacing: 0.05em;
    transition: transform var(--transition);
  }
 
  .navbar-logo:hover {
    transform: scale(1.05);
  }
 
  .logo-icon {
    font-size: 1.5rem;
    animation: bounce 2s infinite;
  }
 
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }
 
  .navbar-links {
    display: flex;
    gap: 0.5rem;
  }
 
  .nav-link {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
    padding: 0.4rem 1rem;
    border-radius: 8px;
    border: 2px solid transparent;
    transition: all var(--transition);
  }
 
  .nav-link:hover {
    color: var(--accent2);
    border-color: var(--accent2);
    background: rgba(251, 208, 0, 0.08);
  }
 
  /* ===== DARK TOGGLE ===== */
  .dark-toggle {
    background: var(--card);
    border: 2px solid var(--border);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    transition: all var(--transition);
  }
 
  .dark-toggle:hover {
    background: var(--accent);
    transform: rotate(20deg);
  }
 
  /* ===== FOOTER ===== */
  .footer {
    text-align: center;
    padding: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    border-top: 2px solid var(--bg2);
  }
 
  /* ===== UTILIDADES ===== */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
 
  .page-title {
    font-family: var(--font-pixel);
    font-size: clamp(0.8rem, 2.5vw, 1.4rem);
    color: var(--accent2);
    text-align: center;
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }
 
  .grid-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }
 
  /* ===== ANIMACIONES ===== */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
 
  .fade-in {
    animation: fadeInUp 0.5s ease forwards;
  }
 
  /* ===== RESPONSIVE ===== */
  @media (max-width: 600px) {
    .navbar {
      padding: 0 1rem;
    }
    .logo-text {
      display: none;
    }
    .nav-link {
      font-size: 0.8rem;
      padding: 0.4rem 0.6rem;
    }
  }
</style>
 
<script>
  const toggle = document.getElementById("darkToggle");
  const html = document.documentElement;
  const icon = toggle?.querySelector(".toggle-icon");
 
  // Cargar preferencia guardada
  const saved = localStorage.getItem("theme") || "dark";
  html.setAttribute("data-theme", saved);
  if (icon) icon.textContent = saved === "dark" ? "🌙" : "☀️";
 
  toggle?.addEventListener("click", () => {
    const current = html.getAttribute("data-theme");
    const next = current === "dark" ? "light" : "dark";
    html.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
    if (icon) icon.textContent = next === "dark" ? "🌙" : "☀️";
  });
</script>